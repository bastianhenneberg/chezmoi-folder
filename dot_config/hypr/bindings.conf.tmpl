# Application bindings
bindd = SUPER ALT, RETURN, Tmux, exec, uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)" tmux new
$terminal = uwsm app -- $TERMINAL
$browser = omarchy-launch-browser

unbind = SUPER SHIFT, SPACE
unbind = SUPER, SPACE
unbind = SUPER SHIFT, W
unbind = SUPER SHIFT, K
unbind = SUPER SHIFT, J
unbind = SUPER, J
unbind = SUPER, L
unbind = SUPER, W
unbind = SUPER, P
unbind = SUPER, K

bindd = SUPER, Y, Toggle workspace layout, exec, omarchy-hyprland-workspace-layout-toggle

bindd = SUPER, RETURN, Terminal, exec, $terminal --working-directory $(omarchy-cmd-terminal-cwd)
bindd = SUPER SHIFT, RETURN, Browser, exec, omarchy-launch-browser
bindd = SUPER SHIFT, F, File manager, exec, uwsm app -- nautilus --new-window
bindd = SUPER SHIFT, E, File explorer (yazi), exec, uwsm app -- ghostty --working-directory=$(omarchy-cmd-terminal-cwd) -e yazi
bindd = SUPER SHIFT, B, Browser, exec, $browser
bindd = SUPER SHIFT ALT, B, Browser (private), exec, $browser --private
bindd = SUPER SHIFT, M, Music, exec, omarchy-launch-or-focus spotify
bindd = SUPER SHIFT ALT, M, Music TUI, exec, omarchy-launch-or-focus-tui cliamp
bindd = SUPER SHIFT, N, Editor, exec, omarchy-launch-editor
bindd = SUPER SHIFT, T, Activity, exec, omarchy-launch-tui btop
bindd = SUPER SHIFT, D, Docker, exec, omarchy-launch-tui lazydocker
bindd = SUPER SHIFT, G, Signal, exec, omarchy-launch-or-focus signal "uwsm app -- signal-desktop"
bindd = SUPER SHIFT, O, Obsidian, exec, omarchy-launch-or-focus obsidian "uwsm-app -- obsidian"
bindd = SUPER SHIFT, slash, Passwords, exec, uwsm app -- 1passwozd

# If your web app url contains #, type it as ## to prevent hyperland treat it as comments
bindd = SUPER SHIFT, A, ChatGPT, exec, omarchy-launch-webapp "https://chatgpt.com"
bindd = SUPER SHIFT ALT, A, Grok, exec, omarchy-launch-webapp "https://grok.com"
bindd = SUPER SHIFT, C, Calendar, exec, omarchy-launch-webapp "https://app.hey.com/calendar/weeks/"
# bindd = SUPER SHIFT, E, Email, exec, omarchy-launch-webapp "https://app.hey.com"
bindd = SUPER SHIFT, Y, YouTube, exec, omarchy-launch-webapp "https://youtube.com/"
bindd = SUPER SHIFT ALT, G, WhatsApp, exec, omarchy-launch-or-focus-webapp WhatsApp "https://web.whatsapp.com/"
bindd = SUPER SHIFT CTRL, G, Google Messages, exec, omarchy-launch-or-focus-webapp "Google Messages" "https://messages.google.com/web/conversations"
bindd = SUPER SHIFT, X, X, exec, omarchy-launch-webapp "https://x.com/"
bindd = SUPER SHIFT ALT, X, X Post, exec, omarchy-launch-webapp "https://x.com/compose/post"

# My Bindings 
bindd = SUPER, R, Launch apps, exec, walker -p "Start…"
bindd = SUPER, Q, Close all Windowns, killactive
bindd = SUPER, SPACE, Switch Keyboard Layout, exec, ~/.config/hypr/scripts/toggle-kb-layout.sh
# Move focus with mainMod + arrow keys
bindd = SUPER, H, Move focus left , movefocus, l
bindd = SUPER, L, Move focus right ,movefocus, r
bindd = SUPER, K, Move focus up, movefocus, u
bindd = SUPER, J, Move focus down, movefocus, d

# Move active window Aroung mainMod + SHIFT + h, j, k, l 
bindd = SUPER SHIFT, H, Move window left , movewindow, l
bindd = SUPER SHIFT, L, Move window right , movewindow, r
bindd = SUPER SHIFT, K, Move window up , movewindow, u
bindd = SUPER SHIFT, J, Move window down , movewindow, d

# Switch Layout und Keyboard Shortcuts Rebind
bindd = SUPER, I, Show key bindings, exec, omarchy-menu-keybindings
bindd = SUPER SHIFT, Z, Toggle split, layoutmsg, togglesplit

# qtile-Mode: Workspace-Wechsel optional immer auf den Haupt-Monitor holen
# Toggle via Super+Alt+Q (siehe ~/.config/hypr/scripts/)
bindd = SUPER ALT, Q, Toggle qtile-Mode, exec, ~/.config/hypr/scripts/toggle-qtile-mode.sh
unbind = SUPER, code:10
unbind = SUPER, code:11
unbind = SUPER, code:12
unbind = SUPER, code:13
unbind = SUPER, code:14
unbind = SUPER, code:15
unbind = SUPER, code:16
unbind = SUPER, code:17
unbind = SUPER, code:18
unbind = SUPER, code:19
bindd = SUPER, code:10, Switch to workspace 1, exec, ~/.config/hypr/scripts/ws-switch.sh 1
bindd = SUPER, code:11, Switch to workspace 2, exec, ~/.config/hypr/scripts/ws-switch.sh 2
bindd = SUPER, code:12, Switch to workspace 3, exec, ~/.config/hypr/scripts/ws-switch.sh 3
bindd = SUPER, code:13, Switch to workspace 4, exec, ~/.config/hypr/scripts/ws-switch.sh 4
bindd = SUPER, code:14, Switch to workspace 5, exec, ~/.config/hypr/scripts/ws-switch.sh 5
bindd = SUPER, code:15, Switch to workspace 6, exec, ~/.config/hypr/scripts/ws-switch.sh 6
bindd = SUPER, code:16, Switch to workspace 7, exec, ~/.config/hypr/scripts/ws-switch.sh 7
bindd = SUPER, code:17, Switch to workspace 8, exec, ~/.config/hypr/scripts/ws-switch.sh 8
bindd = SUPER, code:18, Switch to workspace 9, exec, ~/.config/hypr/scripts/ws-switch.sh 9
bindd = SUPER, code:19, Switch to workspace 10, exec, ~/.config/hypr/scripts/ws-switch.sh 10

# Overwrite existing bindings, like putting Omarchy Menu on Super + Space
# unbind = SUPER SHIFT, SPACE
# bindd = SUPER SHIFT, SPACE, Omarchy menu, exec, omarchy-menu

# hyprwhspr - Toggle mode (added by hyprwhspr setup)
# Press once to start, press again to stop
bindd = SUPER ALT, D, Speech-to-text, exec, /usr/lib/hyprwhspr/config/hyprland/hyprwhspr-tray.sh record

# TigerVNC Menu (F8) über Tastenkombination
bindd = SUPER ALT CTRL, O, TigerVNC Menu, exec, xdotool key F8

# TigerVNC Passthrough-Modus (alle Tasten an VNC durchreichen)
bindd = SUPER ALT CTRL, P, VNC Passthrough ein, submap, vnc_passthrough
submap = vnc_passthrough
bindd = SUPER ALT CTRL, P, VNC Passthrough aus, submap, reset
submap = reset
