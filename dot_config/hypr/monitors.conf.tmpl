# See https://wiki.hyprland.org/Configuring/Monitors/
# List current monitors and resolutions possible: hyprctl monitors
# Format: monitor = [port], resolution, position, scale
# You must relaunch Hyprland after changing any envs (use Super+Esc, then Relaunch)

{{ if eq .machine "desktop" -}}
env = GDK_SCALE,1
# Desktop Setup (3 Monitore, v.l.n.r.)
# Samsung LC27G7xT (DP-3) | BenQ PD2700U (DP-2, Main, 4K) | BenQ ZOWIE XL (DP-1)
monitor=DP-3,2560x1440@240,0x0,1
monitor=DP-2,3840x2160@60,2560x0,1
monitor=DP-1,1920x1080@240,6400x0,1

# Workspace-Zuweisung (1=links Samsung, 2/4/5+=Mitte BenQ, 3=rechts ZOWIE)
workspace = 1, monitor:DP-3, default:true
workspace = 2, monitor:DP-2, default:true
workspace = 3, monitor:DP-1, default:true
workspace = 4, monitor:DP-2
workspace = 5, monitor:DP-2
# Alle weiteren Workspaces (6+) ebenfalls auf dem mittleren Monitor
workspace = 6, monitor:DP-2
workspace = 7, monitor:DP-2
workspace = 8, monitor:DP-2
workspace = 9, monitor:DP-2
workspace = 10, monitor:DP-2

{{ else if eq .machine "laptop" -}}
env = GDK_SCALE,1
# Laptop Setup
monitor=eDP-2,2560x1440@240,0x0,1
# HDMI Monitor Büro
monitor=HDMI-A-1,3840x2560@50,2560x0,1

# Workspace-Zuweisung
workspace = 1, monitor:eDP-2, default:true
workspace = 2, monitor:HDMI-A-1, default:true
workspace = 4, monitor:HDMI-A-1
workspace = 5, monitor:HDMI-A-1

{{ else if eq .machine "omarchy" -}}
# omarchy (Prod) — Huawei MateView (HDMI-A-1, 3840x2560@50), HiDPI Auto-Detect
env = GDK_SCALE,2
monitor=,preferred,auto,auto

{{ else -}}
env = GDK_SCALE,1
# Fallback: auto-detect
monitor=,preferred,auto,auto

{{ end -}}
