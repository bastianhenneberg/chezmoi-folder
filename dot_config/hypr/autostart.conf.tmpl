{{ if eq .machine "omarchy" -}}
# Extra autostart processes
# exec-once = uwsm-app -- my-service
#
# exec-once = sleep 3 && rustdesk --service
{{- else -}}
# Extra autostart processes
# Netzlaufwerk mounten (wartet auf Netbird + Server erreichbar)
exec-once = bash -c 'until ping -c1 -W1 100.97.97.130 &>/dev/null; do sleep 2; done; sleep 1; mount /mnt/netzwerk-vault'

# Workspaces auf externem Monitor erstellen
exec-once = sleep 1 && hyprctl dispatch workspace 2 && hyprctl dispatch workspace 4 && hyprctl dispatch workspace 5

# Workspace 1 (eDP-2): Zen Browser
exec-once = sleep 2 && uwsm app -- zen-browser

# Workspace 5 (HDMI-A-1): Thunderbird
exec-once = sleep 3 && uwsm app -- thunderbird

# Workspace 4 (HDMI-A-1): Obsidian (wartet auf Netzlaufwerk)
# exec-once = bash -c 'while ! mountpoint -q /mnt/netzwerk-vault; do sleep 2; done; sleep 1; uwsm app -- obsidian'

# Workspace 4 (HDMI-A-1): Ghostty (ohne tmux, da wir Herd nutzen)
exec-once = sleep 5 && uwsm app -- ghostty --title=Ghostty-WS4

# Workspace 2 (HDMI-A-1): Ghostty (ohne tmux, da wir Herd nutzen)
exec-once = sleep 8 && uwsm app -- ghostty --title=Ghostty-WS2
{{- end -}}
