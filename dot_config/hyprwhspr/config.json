{
  "$schema": "https://raw.githubusercontent.com/goodroot/hyprwhspr/main/share/config.schema.json",
  "use_hypr_bindings": true,
  "transcription_backend": "faster-whisper",
  "faster_whisper_model": "large-v3",
  "faster_whisper_device": "auto",
  "faster_whisper_compute_type": "float16",
  "faster_whisper_vad_filter": true,
  "language": "de",
  "task": "transcribe",
  "sampling_strategy": "beam_search",
  "beam_size": 5,
  "whisper_prompt": "Transkribiere auf Deutsch mit korrekter Groß- und Kleinschreibung, Satzzeichen, Eigennamen und gängigen Fachbegriffen.",
  "audio_ducking": true
}
